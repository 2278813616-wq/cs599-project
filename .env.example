# LLM
LLM_API_KEY=your_llm_api_key_here
LLM_API_BASE=https://api.bianxie.ai/v1
LLM_MODEL=deepseek-v4-pro
LLM_TIMEOUT_SECONDS=35
LLM_FAST_TIMEOUT_SECONDS=10
LLM_SEND_ENABLE_THINKING=0
HOME_RECIPE_PLAN_CACHE_TTL_SECONDS=86400
HOME_RECIPE_PLAN_MAX_TOKENS=500
HOME_RECIPE_DETAIL_MAX_TOKENS=850
HOME_RECIPE_DETAIL_REQUEST_TIMEOUT_SECONDS=25
HOME_RECIPE_DETAIL_TIMEOUT_SECONDS=30

# Food search behavior
# online_required: fail when online search fails
# online_first: try online first, allow fallback only when FOOD_SEARCH_ALLOW_FALLBACK=1
# offline_only: deterministic local cache mode for tests
FOOD_SEARCH_MODE=online_required
FOOD_SEARCH_ALLOW_FALLBACK=0
FOOD_SEARCH_RETRIES=2
FOOD_SEARCH_SOCIAL_FAST_RETURN=1
FOOD_SEARCH_TAVILY_FAST_RETURN=1
FOOD_SEARCH_CONTEXT_RESULTS=4
HOME_RECIPE_SOURCE_MODE=tavily_only
AIONE_XHS_HOME_DETAIL_CANDIDATE_LIMIT=1
AIONE_XHS_HOME_DETAIL_TIMEOUT_SECONDS=25
AIONE_XHS_PROBE_TIMEOUT_SECONDS=6
HOME_RECIPE_XHS_WAIT_SECONDS=10
AIONE_XHS_REFRESH_WEAK_CACHE=1

# Tavily fallback, optional and paid
TAVILY_API_KEY=your_tavily_api_key_here
TAVILY_TIMEOUT_SECONDS=12
TAVILY_INCLUDE_IMAGES=1
TAVILY_INCLUDE_IMAGE_DESCRIPTIONS=1
TAVILY_RECIPE_EXTRACT_TIMEOUT_SECONDS=8
TAVILY_RECIPE_EXTRACT_MAX_TOKENS=850
TAVILY_RECIPE_EXTRACT_CACHE_TTL_SECONDS=604800
TAVILY_RECIPE_EXTRACT_CACHE_MAX_ITEMS=500

# all-in-one / XHS local-only integration
# Do not deploy XHS cookies to cloud services.
AIONE_ENABLED=0
AIONE_CLI_PATH=venv\Scripts\aione.exe
AIONE_NODE_DIR=E:\tools\nodejs
AIONE_TIMEOUT_SECONDS=20
AIONE_XHS_TAVILY_FALLBACK=1
AIONE_XHS_TAVILY_MAX_RESULTS=5
AIONE_XHS_SEARCH_CANDIDATE_LIMIT=6
AIONE_XHS_DETAIL_LIMIT=3
AIONE_XHS_DINING_DETAIL_LIMIT=4
AIONE_XHS_RESTAURANT_NOTE_DETAIL_LIMIT=1
AIONE_XHS_RESTAURANT_NOTE_TIMEOUT_SECONDS=6
AIONE_XHS_RESTAURANT_NOTE_LIVE_LOOKUP=0
AIONE_XHS_RECIPE_EXTRACT_LIMIT=1
AIONE_XHS_RECIPE_EXTRACT_CONCURRENCY=3
AIONE_XHS_RECIPE_EXTRACT_TIMEOUT_SECONDS=12
AIONE_XHS_RECIPE_EXTRACT_MAX_TOKENS=750
AIONE_XHS_RECIPE_EXTRACT_CACHE_TTL_SECONDS=604800
AIONE_XHS_RECIPE_EXTRACT_CACHE_MAX_ITEMS=500
AIONE_XHS_RECIPE_SKIP_WEAK_TEXT=0
AIONE_XHS_SOCIAL_SEARCH_CACHE_TTL_SECONDS=1800
AIONE_XHS_SOCIAL_SEARCH_CACHE_MAX_ITEMS=100
AIONE_XHS_COMMENT_STORE_LOOKUP=0
AIONE_XHS_COMMENT_STORE_LOOKUP_LIMIT=3
AIONE_XHS_COMMENT_TIMEOUT_SECONDS=20
AIONE_XHS_COOKIES=
AIONE_XHS_PC_COOKIES=

# Douyin is currently disabled for this project.
AIONE_DOUYIN_ENABLED=0

# Milvus
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_FORCE_MOCK=0

# Gaode / AMap
GAODE_API_KEY=your_gaode_api_key_here
GAODE_JS_API_KEY=your_gaode_js_api_key_here
GAODE_JS_SECURITY_CODE=your_gaode_js_security_code_here
GAODE_DEFAULT_CITY=武汉
GAODE_POI_TIMEOUT_SECONDS=5
GAODE_ENTERTAINMENT_KEYWORDS=电影院,电玩城,台球,猫咖,展览
GAODE_ENTERTAINMENT_KEYWORD_LIMIT=5

# Business-area performance controls
GAODE_MAP_TIMEOUT_SECONDS=5
MAP_BUSINESS_AREA_CACHE_TTL_SECONDS=86400
MAP_BUSINESS_AREA_RESULT_LIMIT=24

# Python encoding
PYTHONIOENCODING=utf-8
PYTHONUTF8=1
