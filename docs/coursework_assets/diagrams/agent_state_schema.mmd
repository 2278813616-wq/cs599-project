flowchart TD
    subgraph Inputs["用户输入与上下文 (Inputs)"]
        user_input[用户原始输入]
        dining_people_count[用餐人数]
        current_disease[当前健康状态/疾病]
        business_area_context[商圈上下文]
    end

    subgraph Memory["记忆与足迹上下文 (Memory)"]
        recent_eaten[近期已吃菜品/足迹]
    end

    subgraph Outputs["系统生成与输出 (Outputs)"]
        recommendations[推荐候选列表]
        report_path[PDF 报告文件路径]
    end

    subgraph State["智能体状态规格 (Agent State Schema)"]
        session_id[会话标识 ID]
        user_id[用户标识 ID]
        mode[工作模式]
        user_input_state[用户输入]
        current_disease_state[当前健康状况]
        dining_people_count_state[用餐人数]
        business_area_context_state[商圈信息]
        selected_items[已加菜单/已选餐厅]
    end

    subgraph Runtime["状态机运行时字段 (Runtime)"]
        recent_eaten_rt[近期足迹]
        graph_rag_path[Graph-RAG 规则冲突路径]
        health_explanation[健康解释/禁忌说明]
        recommendations_rt[结构化推荐数据]
        recommendation_text[推荐陈述文本]
        report_path_rt[生成的 PDF 路径]
    end

    Input --> LM[加载记忆节点 load_memory_node]
    LM --> recent_eaten_rt
    Runtime --> IP[意图解析节点 intent_parse_node]
    IP --> CHEF[自己做节点 chef_node 写入菜谱推荐]
    IP --> GOURMET[出去吃节点 gourmet_node 写入餐厅推荐]
    CHEF --> report_path_rt
    GOURMET --> report_path_rt
